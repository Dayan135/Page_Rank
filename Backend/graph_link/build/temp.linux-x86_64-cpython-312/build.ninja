cxx = /home/dayanb/.conda/envs/pageRank_312/bin/x86_64-conda-linux-gnu-c++
nvcc = /usr/local/cuda-12.5/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/dayanb/.conda/envs/pageRank_312/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/dayanb/.conda/envs/pageRank_312/include -fPIC -I/home/dayanb/SoftwareProjectPageRank/Backend/graph_link -Iext/cuCollections/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/TH -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/THC -I/usr/local/cuda-12.5/include -I/home/dayanb/.conda/envs/pageRank_312/include/python3.12 -c
post_cflags = -DCUDA_ENABLED=1 -O3 -std=c++17 -w -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=graph_link_core -D_GLIBCXX_USE_CXX11_ABI=0
cuda_cflags = -I/home/dayanb/SoftwareProjectPageRank/Backend/graph_link -Iext/cuCollections/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/TH -I/home/dayanb/.conda/envs/pageRank_312/lib/python3.12/site-packages/torch/include/THC -I/usr/local/cuda-12.5/include -I/home/dayanb/.conda/envs/pageRank_312/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -std=c++17 -lineinfo -O3 -allow-unsupported-compiler -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=graph_link_core -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=sm_86 -ccbin /home/dayanb/.conda/envs/pageRank_312/bin/x86_64-conda-linux-gnu-cc
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





